# Copy this file to .env and fill in the values below. Never commit .env.
#
# DigitalOcean API token with read+write scope.
# Create at: https://cloud.digitalocean.com/account/api/tokens
DIGITALOCEAN_TOKEN=

# Tailscale OAuth client for the Kubernetes operator.
# Create at: https://login.tailscale.com/admin/settings/oauth
# Required scopes: devices:core (write), auth_keys (write).
#
# BEFORE creating the OAuth client, ensure these tags exist in your tailnet
# Access Controls (https://login.tailscale.com/admin/acls/file):
#   - tag:k8s-operator   (the operator itself runs as this tag)
#   - tag:k8s            (Tailscale-managed proxy devices for ingresses run as this tag)
#
# When creating the OAuth client, scope it to `tag:k8s-operator`.
TS_OPERATOR_CLIENT_ID=
TS_OPERATOR_CLIENT_SECRET=
